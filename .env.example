ENV=local
SERVICE_NAME=knowledge-alakazam
LOG_LEVEL=INFO
HEALTH_CHECK_TIMEOUT_SECONDS=1.0
HEALTH_CHECK_S3=false

POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
APP_DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag

RAG_WORKING_DIR=./storage/lightrag
RAG_OUTPUT_DIR=./storage/output
RAG_INPUT_DIR=./storage/inputs
PARSER=mineru
PARSE_METHOD=auto
INGEST_SYNC=true
WORKER_POLL_INTERVAL_SECONDS=5.0

OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=gpt-4.1-mini
VISION_MODEL=gpt-4.1-mini
EMBEDDING_BASE_URL=http://127.0.0.1:1234/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
RAG_RUNTIME_DISABLED=true
RAG_ENABLE_IMAGE_PROCESSING=true
RAG_ENABLE_TABLE_PROCESSING=true
RAG_ENABLE_EQUATION_PROCESSING=true

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION_NAME=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_RAW=rag-raw
S3_BUCKET_ASSETS=rag-assets

LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_VECTOR_STORAGE=PGVectorStorage
LIGHTRAG_GRAPH_STORAGE=PGGraphStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage

PGVECTOR_VERSION=v0.8.4
INSTALL_RAG_EXTRAS=false
